<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:msaui="http://schemas.android.com/apk/res-auto" android:orientation="vertical" android:padding="12dp" android:layout_width="match_parent" android:layout_height="match_parent">
    <com.microsoft.xbox.toolkit.ui.SwitchPanel android:id="@+id/friend_finder_confirm_switchpanel" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="@dimen/profilePivotPageContentMarginTop" msaui:selectedState="0">
        <com.microsoft.xbox.toolkit.ui.SwitchPanelItem android:layout_gravity="center" android:layout_width="match_parent" android:layout_height="match_parent" msaui:state="0">
            <LinearLayout android:layout_gravity="top|center_vertical|center_horizontal|center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <com.microsoft.xbox.toolkit.ui.CustomTypefaceTextView android:textSize="@dimen/friendFinderConfirmDialogTitleSize" android:ellipsize="end" android:id="@+id/friend_finder_confirm_message_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:layout_marginBottom="12dp" android:layout_alignParentLeft="true" style="@style/SUI_white"/>
                    <com.microsoft.xbox.toolkit.ui.XLEButton android:gravity="right" android:id="@+id/friend_finder_dialog_close" android:background="@drawable/common_button_background" android:padding="8dp" android:layout_width="match_parent" android:text="@string/ic_Close" android:layout_alignParentTop="true" android:contentDescription="@string/MessageDialog_Cancel" style="@style/xbox_symbol"/>
                </RelativeLayout>
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:layout_marginBottom="12dp">
                    <com.microsoft.xbox.toolkit.ui.CustomTypefaceTextView android:textColor="@color/warningIconColor" android:ellipsize="end" android:gravity="center_vertical" android:id="@+id/friend_finder_error_symbol" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="15dp" android:layout_marginRight="15dp" android:text="@string/ic_Warning" android:layout_alignParentLeft="true" style="@style/xbox_symbol"/>
                    <com.microsoft.xbox.toolkit.ui.CustomTypefaceTextView android:textSize="@dimen/friendFinderConfirmDialogBodySize" android:ellipsize="end" android:layout_gravity="left" android:id="@+id/friend_finder_confirm_message_error" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toRightOf="@+id/friend_finder_error_symbol" style="@style/SUI_white"/>
                </RelativeLayout>
                <com.microsoft.xbox.toolkit.ui.CustomTypefaceTextView android:textSize="@dimen/friendFinderConfirmDialogErrorSize" android:ellipsize="end" android:layout_gravity="left" android:id="@+id/friend_finder_confirm_message_text" android:layout_width="wrap_content" android:layout_height="0dp" android:layout_marginTop="12dp" android:layout_marginBottom="12dp" android:layout_weight="1" style="@style/SUI_white"/>
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:weightSum="2">
                    <com.microsoft.xbox.toolkit.ui.XLEButton android:gravity="center" android:id="@+id/friend_finder_confirm_button" android:background="@color/mediumGray" android:layout_width="0dp" android:layout_height="40dp" android:layout_marginRight="4dp" android:text="" android:layout_weight="1"/>
                    <com.microsoft.xbox.toolkit.ui.XLEButton android:gravity="center" android:id="@+id/friend_finder_cancel_button" android:background="@color/mediumGray" android:layout_width="0dp" android:layout_height="40dp" android:text="@string/MessageDialog_Cancel" android:layout_weight="1"/>
                </LinearLayout>
            </LinearLayout>
            <com.microsoft.xbox.toolkit.ui.FastProgressBar android:layout_gravity="center" android:id="@+id/overlay_loading_indicator" android:visibility="gone" android:layout_width="64dp" android:layout_height="64dp" android:indeterminateOnly="true" android:indeterminateDrawable="@drawable/rotate_loading_rings_small"/>
        </com.microsoft.xbox.toolkit.ui.SwitchPanelItem>
        <com.microsoft.xbox.toolkit.ui.SwitchPanelItem android:layout_gravity="center" android:layout_width="match_parent" android:layout_height="match_parent" msaui:state="1">
            <com.microsoft.xbox.toolkit.ui.FastProgressBar android:layout_gravity="center" android:layout_width="64dp" android:layout_height="64dp" android:indeterminateOnly="true" android:indeterminateDrawable="@drawable/rotate_loading_rings_small"/>
        </com.microsoft.xbox.toolkit.ui.SwitchPanelItem>
    </com.microsoft.xbox.toolkit.ui.SwitchPanel>
</LinearLayout>
