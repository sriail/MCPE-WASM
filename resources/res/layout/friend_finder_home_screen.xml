<?xml version="1.0" encoding="utf-8"?>
<com.microsoft.xbox.xle.ui.XLERootView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:msaui="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent">
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:orientation="vertical" android:padding="@dimen/friendFinderPageMargin" android:layout_width="match_parent" android:layout_height="wrap_content">
            <com.microsoft.xbox.toolkit.ui.CustomTypefaceTextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/FriendFinder_PhoneContacts_GamingIsBetter_Dialog_Title" style="@style/FriendFinder_Title"/>
            <com.microsoft.xbox.toolkit.ui.CustomTypefaceTextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="@string/FriendFinder_PhoneNoContacts_GamingIsBetter_Dialog_Text" style="@style/standard_text"/>
            <com.microsoft.xbox.toolkit.ui.CustomTypefaceTextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/friendFinderVerticalMargin" android:layout_marginBottom="@dimen/friendFinderVerticalMargin" android:text="@string/FriendFinder_OptIn" style="@style/FriendFinder_Title"/>
            <com.microsoft.xbox.xle.ui.ImageTitleSubtitleButton android:id="@+id/friendfinder_link_facebook" android:background="@drawable/common_button_background" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" msaui:text_title="@string/FriendFinder_LinkFacebook_Subtext" msaui:text_subtitle="@string/FriendFinder_Link_Facebook"/>
            <com.microsoft.xbox.xle.ui.IconFontSubTextButton android:id="@+id/friendfinder_link_phone" android:background="@drawable/common_button_background" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" msaui:text_title="@string/FriendFinder_Link_Phone" msaui:text_subtitle="@string/FriendFinder_Link_Phone_Subtext" msaui:icon_uri="@string/ic_PhoneCall" msaui:icon_bg="@color/white_15_percent"/>
            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp">
                <com.microsoft.xbox.xle.ui.IconFontSubTextButton android:id="@+id/friendfinder_link_search" android:background="@drawable/common_button_background" android:layout_width="match_parent" android:layout_height="wrap_content" msaui:text_title="@string/FriendFinder_Find_By_Gamertag" msaui:text_subtitle="@string/FriendFinder_Find_By_Gamertag_Subtext" msaui:icon_uri="@string/ic_Search" msaui:icon_bg="@color/white_15_percent"/>
                <RelativeLayout android:id="@+id/friendfinder_search_layout" android:background="@color/backgroundColor" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <FrameLayout android:id="@+id/friendfinder_search_icon" android:background="@drawable/friendfinder_home_search_background" android:focusable="true" android:clickable="true" android:layout_width="@dimen/friendFinderIconButtonHeight" android:layout_height="@dimen/friendFinderIconButtonHeight" android:layout_marginRight="@dimen/friendFinderPageMargin" android:layout_alignParentLeft="true" android:layout_centerVertical="true" android:contentDescription="@string/FriendFinder_Find_By_Gamertag_Subtext">
                        <com.microsoft.xbox.toolkit.ui.CustomTypefaceTextView android:gravity="center" android:layout_width="@dimen/friendFinderIconButtonWidth" android:layout_height="@dimen/friendFinderIconButtonHeight" android:text="@string/ic_Search" style="@style/xbox_symbol"/>
                    </FrameLayout>
                    <View android:background="@color/white_10_percent" android:layout_width="match_parent" android:layout_height="1dp" android:layout_toRightOf="@+id/friendfinder_search_icon" android:layout_alignParentTop="true"/>
                    <View android:background="@color/white_10_percent" android:layout_width="match_parent" android:layout_height="1dp" android:layout_toRightOf="@+id/friendfinder_search_icon" android:layout_alignParentBottom="true"/>
                    <EditText android:id="@+id/friendfinder_search_edittext" android:background="@android:color/transparent" android:layout_width="match_parent" android:layout_height="match_parent" android:hint="@string/FriendFinder_Find_By_Gamertag" android:layout_toRightOf="@+id/friendfinder_search_icon" android:layout_centerVertical="true" android:imeOptions="actionSearch"/>
                </RelativeLayout>
            </FrameLayout>
            <com.microsoft.xbox.toolkit.ui.CustomTypefaceTextView android:id="@+id/friendfinder_home_invite_friends_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/friendFinderVerticalMargin" android:layout_marginBottom="@dimen/friendFinderVerticalMargin" android:text="@string/FriendFinder_InviteFriends" style="@style/FriendFinder_Title"/>
            <com.microsoft.xbox.xle.ui.ImageTitleSubtitleButton android:id="@+id/friendfinder_home_invite_facebook" android:background="@drawable/common_button_background" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" msaui:text_title="@string/FriendFinder_LinkFacebook_Subtext" msaui:text_subtitle="@string/FriendFinder_Facebook_ViewSuggestion_Buttontext"/>
            <com.microsoft.xbox.xle.ui.IconFontSubTextButton android:id="@+id/friendfinder_home_invite_phone" android:background="@drawable/common_button_background" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" msaui:text_title="@string/FriendFinder_Link_Phone" msaui:text_subtitle="@string/FriendFinder_Facebook_ViewSuggestion_Buttontext" msaui:icon_uri="@string/ic_PhoneCall" msaui:icon_bg="@color/white_15_percent"/>
            <com.microsoft.xbox.toolkit.ui.XLEButton android:layout_gravity="center" android:id="@+id/friendfinder_home_done" android:visibility="visible" android:layout_width="250dp" android:layout_height="wrap_content" android:layout_marginTop="@dimen/friendFinderVerticalMargin" android:text="@string/TextInput_Confirm" style="@style/friendfinder_button"/>
        </LinearLayout>
    </ScrollView>
    <FrameLayout android:id="@+id/friendfinder_home_loading" android:background="@color/backgroundColor" android:layout_width="match_parent" android:layout_height="match_parent">
        <com.microsoft.xbox.toolkit.ui.FastProgressBar android:layout_gravity="center" android:visibility="visible" android:layout_width="64dp" android:layout_height="64dp" android:indeterminateOnly="true" android:indeterminateDrawable="@drawable/rotate_loading_rings_small"/>
    </FrameLayout>
</com.microsoft.xbox.xle.ui.XLERootView>
